# =========================================
# Avisus - template de ambiente
# Copie para .env.local no desenvolvimento.
# Em producao/staging, configure no painel da Vercel.
# =========================================

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_STARTER_MONTHLY=price_your_starter_monthly_id
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_id

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Scanner marketplaces
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key
MAGALU_SCRAPE_MODE=managed
MERCADO_LIVRE_SCRAPE_MODE=managed

# Live monitor (Apify)
APIFY_TOKEN=your_apify_token
APIFY_TIKTOK_ACTOR_ID=apify/tiktok-scraper
APIFY_SHOPEE_ACTOR_ID=apify/shopee-live-scraper

# Cron / feature flags
CRON_SECRET=your_strong_cron_secret
ENABLE_SCANNER_CRON=true
ENABLE_TELEGRAM_ALERTS=true
ENABLE_SHOPEE_LIVE=true
ENABLE_TIKTOK_LIVE=true

# Sentry
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=your_sentry_project_slug
SENTRY_AUTH_TOKEN=your_sentry_auth_token
